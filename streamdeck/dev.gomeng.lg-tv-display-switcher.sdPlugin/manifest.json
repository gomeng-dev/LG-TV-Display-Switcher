{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "imgs/actions/power-icon",
      "Name": "TV Power Toggle",
      "States": [
        {
          "Image": "imgs/actions/power",
          "Title": "TV Power"
        }
      ],
      "Tooltip": "Toggle the LG TV power using LG-TV-Display-Switcher.",
      "UUID": "dev.gomeng.lg-tv-display-switcher.tv-power-toggle"
    },
    {
      "Icon": "imgs/actions/display-mode-icon",
      "Name": "Display Mode Switch",
      "States": [
        {
          "Image": "imgs/actions/pc-mode",
          "Title": "PC Mode"
        },
        {
          "Image": "imgs/actions/tv-mode",
          "Title": "TV Mode"
        }
      ],
      "Tooltip": "Toggle between PC mode and TV mode.",
      "UUID": "dev.gomeng.lg-tv-display-switcher.display-mode-toggle"
    },
    {
      "Icon": "imgs/actions/auto-switch-icon",
      "Name": "Toggle Auto Switch",
      "States": [
        {
          "Image": "imgs/actions/auto-switch",
          "Title": "Auto"
        }
      ],
      "Tooltip": "Toggle automatic switching when TV power changes.",
      "UUID": "dev.gomeng.lg-tv-display-switcher.toggle-auto-switch"
    }
  ],
  "Author": "gomeng-dev",
  "Category": "LG TV Display Switcher",
  "CategoryIcon": "imgs/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "Control LG TV display, power, and audio switching through the LG-TV-Display-Switcher companion app.",
  "Icon": "imgs/plugin-icon",
  "Name": "LG TV Display Switcher",
  "Nodejs": {
    "Version": "20"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "SupportURL": "https://github.com/gomeng-dev/LG-TV-Display-Switcher/issues",
  "URL": "https://github.com/gomeng-dev/LG-TV-Display-Switcher",
  "UUID": "dev.gomeng.lg-tv-display-switcher",
  "Version": "0.1.6.0"
}